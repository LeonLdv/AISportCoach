{
  "Jwt": {
    "Issuer": "AISportCoach.API",
    "Audience": "AISportCoach.WebApp",
    "AccessTokenExpiryMinutes": 60,
    "RefreshTokenExpiryDays": 30
  },
  "Email": {
    "FromEmail": "noreply@aisportcoach.local",
    "FromName": "AISportCoach",
    "ConfirmationUrlTemplate": "https://localhost:19006/confirm-email?token={0}",
    "PasswordResetUrlTemplate": "https://localhost:19006/reset-password?token={0}",
    "ConfirmationTokenExpiryHours": 24,
    "PasswordResetTokenExpiryHours": 1
  },
  "Logging": {
    "LogLevel": {
      "Default": "Debug",
      "Microsoft.AspNetCore": "Information",
      "Microsoft.AspNetCore.Hosting": "Information",
      "Microsoft.AspNetCore.Routing.EndpointMiddleware": "Information",
      "Microsoft.EntityFrameworkCore.Database.Command": "Warning",
      "Microsoft.SemanticKernel": "Debug",
      "AISportCoach": "Debug"
    },
    "Console": {
      "FormatterName": "simple",
      "FormatterOptions": {
        "SingleLine": true,
        "IncludeScopes": true,
        "TimestampFormat": "HH:mm:ss.fff ",
        "UseUtcTimestamp": false
      }
    }
  }
}
